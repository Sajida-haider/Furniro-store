# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/furniro_db

# For SQLite (development only, uncomment to use)
# DATABASE_URL=sqlite+aiosqlite:///./furniro.db

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
FRONTEND_URL=http://localhost:3000

# App
APP_ENV=development
